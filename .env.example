# MomentumTXT / KPIFlow — local environment variables
# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# ---- Required to boot ----
# Neon Postgres connection string (from Replit secrets or Neon dashboard)
DATABASE_URL=

# Clerk authentication (https://dashboard.clerk.com → API Keys)
# VITE_ key is exposed to the browser; the non-prefixed pair is read by @clerk/express on the server.
VITE_CLERK_PUBLISHABLE_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ---- Optional (features degrade gracefully if omitted) ----
# Stripe billing
STRIPE_SECRET_KEY=
VITE_STRIPE_PUBLIC_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_PROFESSIONAL_PRICE_ID=
STRIPE_BUSINESS_PRICE_ID=

# OpenAI (note the custom var name)
KPIFLOWKEY=

# Sendblue SMS (weekly KPI texts). SMS disabled if omitted.
SENDBLUE_API_KEY_ID=
SENDBLUE_API_SECRET_KEY=
SENDBLUE_FROM_NUMBER=
# Shared secret for the Sendblue inbound + delivery-status webhooks.
# Configure the webhook URLs in Sendblue as .../api/sendblue/inbound?token=<this>
SENDBLUE_WEBHOOK_SECRET=

# Server port (defaults to 5000)
PORT=5000
